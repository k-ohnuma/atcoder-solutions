  "db_name": "PostgreSQL",
  "query": "\n                SELECT c.id, c.user_id, u.user_name, c.solution_id, c.body_md, c.created_at, c.updated_at\n                FROM comments c\n                JOIN users u ON c.user_id = u.id\n                WHERE c.solution_id = $1\n                ORDER BY c.created_at ASC\n            ",
