  "query": "\n            SELECT p.id, p.contest_code, p.problem_index, p.title\n            FROM problems p\n            JOIN contests c ON c.code = p.contest_code\n            JOIN contest_series s ON s.code = c.series_code\n            WHERE p.contest_code = $1\n            ",
